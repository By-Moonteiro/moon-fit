generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  password     String
  refreshToken String?       @map("refresh_token")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  workoutPlans WorkoutPlan[]

  @@map("users")
}

model WorkoutPlan {
  id        String   @id @default(cuid())
  name      String
  endDate   DateTime @map("end_date")
  status    String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  trainingDays TrainingDay[]

  @@map("workout_plans")
}

model TrainingDay {
  id            String   @id @default(cuid())
  name          String
  order         Int
  workoutPlanId String   @map("workout_plan_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workoutPlan WorkoutPlan  @relation(fields: [workoutPlanId], references: [id])
  workoutSets WorkoutSet[]

  @@map("training_days")
}

model WorkoutSet {
  id            String   @id @default(cuid())
  exerciseId    String   @map("exercise_id")
  trainingDayId String   @map("training_day_id")
  repetitions   Int
  weight        Float
  restTime      Int      @map("rest_time")
  order         Int
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  exercise    Exercise    @relation(fields: [exerciseId], references: [id])
  trainingDay TrainingDay @relation(fields: [trainingDayId], references: [id])

  @@map("workout_sets")
}

model Exercise {
  id                String       @id @default(cuid())
  name              String       @unique @map("exercise_name")
  description       String?
  muscleGroup       String       @map("muscle_group")
  executionMediaUrl String       @map("execution_media_url")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  workoutSets       WorkoutSet[]

  @@map("exercises")
}
