generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trainingSheets TrainingSheet[]

  @@map("users")
}

model TrainingSheet {
  id        String   @id @default(cuid())
  sheetName String   @unique @map("sheet_name")
  userId    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  trainingCategories TrainingCategory[]

  @@map("training_sheets")
}

model TrainingCategory {
  id             String   @id @default(cuid())
  sheetId        String   @map("sheet_id")
  categoryName   String   @map("category_name")
  completionDate DateTime @map("completion_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trainingSheet TrainingSheet @relation(fields: [sheetId], references: [id])
  exercises     Exercise[]

  @@map("training_categories")
}

model Exercise {
  id           String   @id @default(cuid())
  categoryId   String   @map("category_id")
  exerciseName String   @unique @map("exercise_name")
  description  String?
  series       Int?
  repetitions  Int?
  restTime     Int?     @map("rest_time")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  trainingCategory TrainingCategory @relation(fields: [categoryId], references: [id])

  @@map("exercises")
}
